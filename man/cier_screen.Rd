items <- data.frame(
  scale = sub("^v_BFI_([A-Za-z]+)[0-9].*$", "\\\\1", nm),
  reverse_keyed = grepl("_R$", nm),
  categories = 5L
)
screen <- cier_screen(bfi_careless[, 1:44], items,
