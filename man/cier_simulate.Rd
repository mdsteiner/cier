shipped indices directly: \code{cier_screen(x$responses, x$items)},
\code{\link[=cier_total_time]{cier_total_time()}}\code{(x$seconds)},
\code{\link[=cier_page_time]{cier_page_time()}}\verb{(x$page_seconds, x$items_per_page)}, and
