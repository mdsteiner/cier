linters: linters_with_defaults(
    line_length_linter        = line_length_linter(100L),
    cyclocomp_linter          = cyclocomp_linter(complexity_limit = 20L),
    object_name_linter        = object_name_linter(
      styles = c("snake_case", "SNAKE_CASE", "symbols")
    ),
    object_length_linter      = object_length_linter(length = 40L),
    commented_code_linter     = NULL,
    object_usage_linter       = NULL,
    indentation_linter        = indentation_linter(indent = 2L),
    trailing_whitespace_linter = trailing_whitespace_linter(),
    trailing_blank_lines_linter = trailing_blank_lines_linter()
  )
exclusions: list(
    "tests/reference",
    "inst/validation",
    "docs",
    "vignettes"
  )
encoding: "UTF-8"
